rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "chetri.prem999@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image', 'category', 'stock', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 1000 &&
             data.category is string &&
             data.stock is number && data.stock >= 0 &&
             data.createdAt == request.time;
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.customerEmail == request.auth.token.email);
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerEmail == request.auth.token.email);
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId) && incoming().customerEmail == request.auth.token.email;
      allow update: if isAdmin() && isValidOrderUpdate(incoming());
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerEmail', 'customerName', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.keys().size() >= 6 &&
             data.customerEmail is string &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidOrderUpdate(data) {
      // Admins can update status, razorpay info
      return data.status in ['pending', 'paid', 'shipped', 'cancelled'] &&
             data.customerEmail == existing().customerEmail &&
             data.createdAt == existing().createdAt;
    }
  }
}
